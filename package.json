{
  "name": "agent-card-readme-generator",
  "version": "0.1.0",
  "description": "Generate a human-readable Markdown README from an A2A AgentCard JSON. Documents identity, capabilities, models, tools (with side-effect-class badges), refusal taxonomy, evaluations, deployment, and safety posture. Sibling of mcp-server-readme-generator for the A2A side.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "author": "mizcausevic-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/mizcausevic-dev/agent-card-readme-generator"
  },
  "keywords": [
    "a2a",
    "agent-cards",
    "agent-to-agent",
    "readme",
    "markdown",
    "documentation",
    "ai-governance",
    "typescript"
  ],
  "bin": {
    "agent-card-readme-generator": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "demo": "tsx src/cli.ts fixtures/agent-card.json",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
